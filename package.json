{
  "name": "audio-converter",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest --watch",
    "build": "npm run copy-ffmpeg && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "copy-ffmpeg": "mkdir -p ./public/lib/ffmpeg/core/dist && cp ./node_modules/@ffmpeg/core-mt/dist/esm/* ./public/lib/ffmpeg/core/dist"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^2.4.5",
    "@tailwindcss/typography": "^0.5.9",
    "@testing-library/dom": "^9.3.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/svelte": "^3.2.2",
    "@testing-library/user-event": "^14.4.3",
    "@tsconfig/svelte": "^4.0.1",
    "@types/lodash": "^4.14.197",
    "autoprefixer": "^10.4.15",
    "jsdom": "^22.1.0",
    "postcss": "^8.4.27",
    "prettier": "^2.8.8",
    "prettier-plugin-svelte": "^2.10.1",
    "prettier-plugin-tailwindcss": "^0.3.0",
    "sass": "^1.65.1",
    "svelte": "^3.59.2",
    "svelte-check": "^3.5.0",
    "svelte-htm": "^1.2.0",
    "tailwindcss": "^3.3.3",
    "tslib": "^2.6.1",
    "vite": "4.3.9",
    "vite-plugin-pwa": "^0.16.4",
    "vitest": "^0.34.1"
  },
  "dependencies": {
    "@ffmpeg/core-mt": "^0.12.2",
    "@ffmpeg/ffmpeg": "^0.12.4",
    "@ffmpeg/util": "^0.12.0",
    "@tailwindcss/forms": "^0.5.4",
    "lodash": "^4.17.21",
    "svelte-spa-router": "^3.3.0"
  },
  "overrides": {
    "svelte-hyperscript": "npm:svelte-hyperscript-3.59-patch@1.2.1"
  }
}
